{
  "configVersion": "v3",
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "app": {
    "appId": 1000001,
    "appType": "app",
    "appName": "Health Extractor",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "SaiTeja",
    "description": "Extracts continuous health metrics to Oracle Cloud."
  },
  "permissions": [
    "device:os.bg.service",
    "data:os.device.info",
    "data:os.sensor.pai",
    "data:os.sensor.sleep",
    "data:os.sensor.heartrate"
  ],
  "module": {
    "page": {
      "pages": [
        "page/index"
      ]
    },
    "app-side": {
      "path": "app-side/index.js"
    }
  },
  "targets": {
    "gtr4": {
      "platforms": [
        {
          "name": "gtr4",
          "deviceSource": 226
        }
      ],
      "designWidth": 466,
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        }
      }
    }
  },
  "defaultLanguage": "en-US"
}
